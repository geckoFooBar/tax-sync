<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F3F4F6">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_bg"
            android:backgroundTint="#F9FAFB"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/ivTaxIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_currency"
                app:tint="#6B7280" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvTaxTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Capital Gains Tax"
            app:layout_constraintBottom_toTopOf="@id/tvTaxSubtitle"
            app:layout_constraintEnd_toStartOf="@id/tvTaxAmount"
            app:layout_constraintStart_toEndOf="@id/iconContainer"
            app:layout_constraintTop_toTopOf="@id/iconContainer"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tvTaxSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="2dp"
            android:textColor="#9CA3AF"
            android:textSize="13sp"
            tools:text="12.5% on Equities"
            app:layout_constraintBottom_toBottomOf="@id/iconContainer"
            app:layout_constraintEnd_toStartOf="@id/tvTaxAmount"
            app:layout_constraintStart_toEndOf="@id/iconContainer"
            app:layout_constraintTop_toBottomOf="@id/tvTaxTitle" />

        <TextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:text="PENDING"
            app:layout_constraintBottom_toTopOf="@id/tvTaxAmount"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvTaxAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="₹15,000"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>